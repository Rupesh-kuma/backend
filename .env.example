# ═══════════════════════════════════════════════
#  ChatIQ — Environment Configuration
# ═══════════════════════════════════════════════

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=https://ai-chat-widget-kohl.vercel.app/

# MongoDB
MONGODB_URI=mongodb+srv://chatiq_user:8L1umctIL81ej6Do@cluster0.3kms2mk.mongodb.net/?appName=Cluster0

# JWT (change this to a random secret string!)
JWT_SECRET=ChatIQ_Secret_Change_This_2024!
JWT_EXPIRES_IN=7d

# ── AI ENGINE ──────────────────────────────────
# ChatIQ uses a 100% built-in AI engine.
# No third-party API key needed!
# Options for AI_PROVIDER: 'local' (default), 'ollama'
AI_PROVIDER=local

# ── OLLAMA Local LLM (optional, advanced) ─────
# Install Ollama: https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# File Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Widget Script URL
WIDGET_SCRIPT_URL=https://ai-chat-widget-backend.onrender.com/widget.js
